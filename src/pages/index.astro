---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

import profilePic from "../assets/ProfilePic.png";
import portfolioPreview from "../assets/Portfolio_Preview.png";
import minesweeperPreview from "../assets/Minesweeper_Preview.png";
---

<Layout>
  <!-- Header -->
  <header
    class="fixed top-0 left-0 z-40 flex h-14 md:h-16 w-full items-center bg-brand px-4 md:px-6 text-on-brand"
  >
    <p class="text-base font-semibold grow">Vinay Gajjar</p>
    <button id="toggle-nav-menu" class="relative size-8">
      <!-- Boostrap Icons list icon -->
      <Icon
        name="bi:list"
        class="absolute inset-0 m-auto size-8 opacity-100 motion-safe:transition-opacity motion-safe:duration-200"
      />
      <!-- Boostrap Icons x icon -->
      <Icon
        name="bi:x"
        class="absolute inset-0 m-auto size-8 opacity-0 motion-safe:transition-opacity motion-safe:duration-200"
      />
    </button>

    <!-- by default, position the left to the right edge of the screen -->
    <nav
      id="nav-menu"
      class="fixed flex flex-col top-14 md:top-16 motion-safe:transition-transform translate-x-full motion-safe:duration-200 left-0 bottom-0 w-full z-80 bg-brand-subtle px-6"
    >
      <ul class="flex flex-col grow place-content-evenly">
        <li class="text-brand text-center text-lg font-bold">
          <a href="#skills">Skills</a>
        </li>
        <li class="text-brand text-center text-lg font-bold">
          <a href="#projects">Projects</a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="flex flex-col grow w-full mx-auto pt-14 md:pt-16">
    <!-- Section 1 -->
    <section id="hero" class="scroll-mt-14 md:scroll-mt-16 my-4 md:my-8 py-8 md:py-16">
      <div class="max-w-3xl mx-auto px-4 text-brand">
        <!-- hero intro -->
        <div class="flex flex-col items-center text-center mb-8 md:mb-10">
          <h1 class="text-4xl md:text-5xl font-bold">Hi, I'm Vinay!</h1>

          <p class="text-lg font-semibold mt-4 max-w-md">
            A product-minded full-stack software developer with a front-end
            focus.
          </p>

          <p class="text-base mt-3 max-w-lg italic text-muted">
            I improve user experiences across web and mobile, and build thoughtful
            features from scratch.
          </p>
        </div>

        <!-- rounded card -->
        <div
          class="flex flex-col items-center rounded-lg border bg-surface p-4 md:p-6"
        >
          <!-- photo -->
          <img
            src={profilePic.src}
            alt="Vinay Gajjar Profile Picture"
            class="h-40 md:h-48 w-40 md:w-48 rounded-full object-cover aspect-square mb-4"
          />

          <!-- personality quote -->
          <p class="pb-4 text-center italic text-brand font-medium">
            As a kid I loved building with Lego. Now, I enjoy building software!
          </p>

          <!-- intro -->
          <p class="text-center text-muted mt-4">
            I'm a full-stack software developer with significant industry experience. But growing up, I never thought “one day I want to be a software developer.”
          </p>

          <!-- expandable story -->
          <div
            class="text-center hidden opacity-0 duration-300"
            id="my-story-expanded-content-wrapper"
          >
            <p id="my-story-expanded-content" class="text-center text-muted mt-2">
              <br />
              Since starting my career I've worked across both back-end and front-end
              and gained experience in almost all parts of the software cycle, from
              initial requirements gathering through to production bug fixes.
              <br /><br />
              But my key strength lies in front-end, where I've gained significant
              experience designing and building complex UI features for bespoke internal
              software applications.
            </p>
          </div>

          <button
            id="my-story-expanded-content-toggle-button"
            class="mt-4 px-4 py-2 text-sm rounded border border-brand hover:cursor-pointer"
          >
            Read more
          </button>
        </div>
      </div>
    </section>

    <section id="skills" class="scroll-mt-14 md:scroll-mt-16">
      <h2
        class="bg-brand-subtle text-brand text-center text-lg font-bold p-2 border"
      >
        Skills
      </h2>
      <!-- content wrapper div -->
      <div class="px-2 py-4 max-w-sm md:max-w-lg lg:max-w-3xl mx-auto">
        <!-- content -->
        <div class="grid grid-cols-1 gap-2 md:grid-cols-3">
          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Backend
            </h3>
            <ul
              class="p-6 md:px-3 flex flex-grow flex-row flex-wrap items-center justify-center content-center gap-2"
            >
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Java
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Spring Boot
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Hibernate
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                REST APIs
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                MySQL
              </li>
            </ul>
          </div>
          <div
            class="flex flex-col items-center rounded-lg border-2 border-brand bg-surface overflow-hidden"
          >
            <h3
              class="w-full text-on-brand bg-brand p-2 text-center border-b font-semibold"
            >
              Frontend
            </h3>
            <p
              class="w-full text-center text-xs text-brand bg-brand-subtle p-2 font-semibold flex items-center justify-center gap-1"
            >
              <Icon
                name="bi:star-fill"
                width="12"
                height="12"
                fill="currentColor"
              />
              my core strengths
            </p>
            <ul
              class="p-6 md:px-3 flex flex-grow flex-row h-full flex-wrap items-center justify-center content-center gap-2"
            >
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                HTML
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                CSS
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                JavaScript
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                React
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Tailwind CSS
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                TypeScript
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Mobile-First Design
              </li>
            </ul>
          </div>
          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Other
            </h3>
            <ul
              class="p-6 md:px-3 flex flex-grow flex-row flex-wrap items-center justify-center content-center gap-2"
            >
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Git
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Figma
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                UI Design
              </li>
              <li class="bg-surface-muted text-muted p-1 px-4 rounded-full">
                Collaboration
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="scroll-mt-14 md:scroll-mt-16">
      <h2
        class="bg-brand-subtle text-brand text-center text-lg font-bold p-2 border"
      >
        Projects
      </h2>
      <!-- content wrapper div -->
      <div class="px-2 py-4 max-w-sm md:max-w-lg lg:max-w-3xl mx-auto">
        <!-- content -->
        <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
          <!-- project cards -->
          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Portfolio Website
            </h3>
            <!-- inner content -->
            <div class="p-4 flex flex-col items-center gap-2">
              <img
                src={portfolioPreview.src}
                alt="Thumbnail of Portfolio Website"
                class="mt-4 h-48 w-full rounded mx-auto my-auto object-cover"
              />
              <p class="flex py-4">
                My personal developer website, where I show my skills, design
                thinking and projects. The website is designed fully from
                scratch in Figma, and built using Astro and Tailwind CSS.
              </p>
              <ul class="flex flex-grow flex-row flex-wrap gap-2">
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Astro
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Tailwind CSS
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Figma
                </li>
              </ul>
              <div class="flex flex-row gap-2 py-4">
                <a
                  href="https://github.com/v-gajjar/vinay-gajjar"
                  class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand text-sm"
                  >GitHub</a
                >
              </div>
            </div>
          </div>

          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Minesweeper
            </h3>
            <!-- inner content -->
            <div class="p-4 flex flex-col items-center gap-2">
              <img
                src={minesweeperPreview.src}
                alt="Thumbnail of Minesweeper Game Board"
                class="mt-4 h-48 w-full rounded mx-auto my-auto object-cover"
              />
              <p class="flex py-4">
                A community-driven, open-source reimagining of the iconic
                Minesweeper game. Not another generic, copycat clone; We're
                evolving the game with modern styling and thoughtful UX.
              </p>
              <ul class="flex flex-grow flex-row flex-wrap gap-2">
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  React
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  TypeScript
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  CSS 3
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  HTML 5
                </li>
              </ul>
              <div class="flex flex-row gap-2 py-4">
                <a
                  href="https://v-gajjar.github.io/Minesweeper/"
                  class="px-4 py-2 text-center w-auto rounded border border-brand text-brand text-sm"
                  >Live Demo</a
                >
                <a
                  href="https://github.com/v-gajjar/Minesweeper"
                  class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand text-sm"
                  >GitHub</a
                >
              </div>
            </div>
          </div>

          <!-- see more projects card -->
          <div
            class="flex p-6 items-center justify-center rounded-lg border bg-surface col-span-full"
          >
            <div class="flex flex-col items-center gap-4">
              <span class="text-center text-brand"
                >Want to see what else I'm building? Take a look at more
                projects on my</span
              >
              <a
                href="https://github.com/v-gajjar"
                class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand"
                >GitHub</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- -footer -->
  <footer
    class="w-full flex flex-col items-center justify-center bg-brand text-on-brand mx-auto py-4"
  >
    <div class="flex flex-col items-center justify-center gap-2">
      <p class="text-center text-sm">© 2025 Vinay Gajjar</p>
      <ul class="flex flex-row items-center justify-center gap-4">
        <li>
          <a href="https://github.com/v-gajjar">
            <!-- GitHub icon -->
            <Icon name="bi:github" width="16" height="16" fill="currentColor" />
          </a>
        </li>

        <li>
          <a href="https://www.linkedin.com/in/vinaygajjar/">
            <!-- LinkedIn icon -->
            <Icon
              name="bi:linkedin"
              width="16"
              height="16"
              fill="currentColor"
            />
          </a>
        </li>

        <li>
          <a href="https://substack.com/@vinaygajjar?">
            <!-- Substack icon  -->
            <Icon
              name="bi:substack"
              width="16"
              height="16"
              fill="currentColor"
            />
          </a>
        </li>
      </ul>
    </div>
  </footer>

  <script>
    /*
      script to toggle expanded content in "My Story" section
    */
    const myStoryExpandedContentToggleButton = document.getElementById(
      "my-story-expanded-content-toggle-button",
    );
    const content = document.getElementById(
      "my-story-expanded-content-wrapper",
    );
    myStoryExpandedContentToggleButton.addEventListener("click", () => {
      content.classList.toggle("hidden");
      content.classList.toggle("opacity-100");
      myStoryExpandedContentToggleButton.innerText =
        myStoryExpandedContentToggleButton.innerText === "Read more"
          ? "Read less"
          : "Read more";
    });
  </script>
</Layout>
