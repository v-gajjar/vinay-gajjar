---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

import profilePic from "../assets/ProfilePic.png";
import portfolioPreview from "../assets/Portfolio_Preview.png";
import minesweeperPreview from "../assets/Minesweeper_Preview.png";
import legoRobotPic from "../assets/Lego_Robot.jpg";
---

<Layout>
  <!-- Header -->
  <header
    class="fixed top-0 left-0 z-40 w-full bg-brand text-on-brand h-14 md:h-16 px-0"
  >
    <div class="flex items-center h-14 md:h-16 w-full mx-auto px-4 md:px-6">
      <p class="text-base font-semibold grow">Vinay Gajjar</p>

      <!-- Desktop nav -->
      <ul class="hidden md:flex flex-row gap-6 text-on-brand font-semibold">
        <li><a href="#my-story" class="hover:underline">My Story</a></li>
        <li><a href="#skills" class="hover:underline">Skills</a></li>
        <li><a href="#projects" class="hover:underline">Projects</a></li>
      </ul>

      <!-- Hamburger for mobile -->
      <button id="toggle-nav-menu" class="relative size-8 md:hidden">
        <!-- Boostrap Icons list icon -->
        <Icon
          name="bi:list"
          class="absolute inset-0 m-auto size-8 opacity-100 motion-safe:transition-opacity motion-safe:duration-200"
        />
        <!-- Boostrap Icons x icon -->
        <Icon
          name="bi:x"
          class="absolute inset-0 m-auto size-8 opacity-0 motion-safe:transition-opacity motion-safe:duration-200"
        />
      </button>
    </div>
    <!-- Mobile nav menu -->
    <nav
      id="nav-menu"
      class="md:hidden fixed flex flex-col top-14 md:top-16 motion-safe:transition-transform translate-x-full motion-safe:duration-200 left-0 bottom-0 w-full z-80 bg-brand-subtle px-6"
    >
      <ul class="flex flex-col grow place-content-evenly">
        <li class="text-brand text-center text-lg font-bold">
          <a href="#my-story">My Story</a>
        </li>
        <li class="text-brand text-center text-lg font-bold">
          <a href="#skills">Skills</a>
        </li>
        <li class="text-brand text-center text-lg font-bold">
          <a href="#projects">Projects</a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="flex flex-col grow w-full mx-auto pt-14 md:pt-16">
    <!-- Section 1 -->
    <section
      id="hero"
      class="scroll-mt-14 md:scroll-mt-16 my-4 md:my-8 py-8 md:py-16 min-h-[calc(100dvh-3.5rem)] md:min-h-[calc(100dvh-4rem)] flex items-center"
    >
      <div class="lg:max-w-4xl xl:max-w-5xl mx-auto px-4 text-brand w-full">
        <!-- Main layout: stacked on mobile, row-reverse on desktop (photo right) -->
        <div
          class="flex flex-col md:flex-row-reverse md:items-center md:justify-between gap-8 md:gap-10"
        >
          <!-- HERO COLUMN: Profile photo -->
          <div
            class="flex justify-center md:justify-end items-center md:items-center w-full md:w-auto"
          >
            <img
              src={profilePic.src}
              alt="Vinay Gajjar Profile Picture"
              class="w-36 h-36 md:w-48 md:h-48 lg:w-60 lg:h-60 xl:w-72 xl:h-72 aspect-square rounded-full object-cover mb-4 md:mb-0"
            />
          </div>
          <!-- HERO COLUMN: Text content -->
          <div
            class="flex flex-col items-center text-center md:items-start md:text-left max-w-lg md:max-w-xl mx-auto w-full"
          >
            <h1 class="text-4xl md:text-6xl font-bold mb-4">Hi, I'm Vinay!</h1>

            <p class="text-lg md:text-xl font-bold mb-4 md:mb-6">
              A product-minded full-stack software developer with a front-end
              focus.
            </p>

            <p class="italic font-medium text-muted mb-6 md:mb-8">
              I transform thoughtful ideas into useful software, one feature at
              a time. Just how I used to build with Lego, one brick at a time.
            </p>

            <a
              href="#projects"
              class="px-5 py-2 rounded bg-brand text-on-brand text-sm mb-4"
            >
              View My Projects
            </a>
          </div>
        </div>

        <!-- Down arrow -->
        <div class="w-full flex justify-center mt-8 md:mt-12">
          <Icon
            class="text-brand size-8 opacity-80 animate-bounce"
            name="bi:arrow-down"
          />
        </div>
      </div>
    </section>

    <section
      id="my-story"
      class="scroll-mt-14 md:scroll-mt-16 my-16 md:my-20 py-6 md:py-8"
    >
      <div class="max-w-4xl mx-auto px-4 py-6 md:py-8 border-t">
        <!-- Title -->
        <h2 class="text-brand text-xl md:text-2xl font-bold mb-6">My Story</h2>

        <!-- Top row -->
        <div
          class="flex flex-col md:flex-row md:items-start gap-6 md:gap-8 mb-6"
        >
          <img
            src={legoRobotPic.src}
            alt="A photo of a Lego robot"
            class="w-32 h-32 md:w-40 md:h-40 rounded object-cover shrink-0"
          />

          <p
            class="text-brand text-lg md:text-xl font-semibold leading-relaxed"
          >
            As a kid I loved building with Lego. Now, I enjoy building software.
          </p>
        </div>

        <!-- Body -->
        <div class="text-base leading-relaxed text-muted">
          <p class="mb-4">
            I'm a full-stack software developer with significant industry
            experience. But growing up, one thought I never had was "one day I
            want to be a software developer."
          </p>

          <!-- Expandable -->
          <div
            id="my-story-expanded-content-wrapper"
            class="hidden opacity-0 transition-opacity duration-300"
          >
            <p>
              <br />
              Since starting my career I've worked across both back-end and front-end
              and gained experience in almost all parts of the software cycle, from
              initial requirements gathering through to production bug fixes.
              <br /><br />
              But my key strength lie in front-end, and I've gained significant experience
              in designing and building complex UI features for bespoke internal software
              applications.
            </p>
          </div>

          <!-- Button -->
          <button
            id="my-story-expanded-content-toggle-button"
            class="mt-6 px-3 py-1.5 rounded border border-brand text-brand text-sm hover:cursor-pointer"
          >
            Read more
          </button>
        </div>
      </div>
    </section>

    <section id="skills" class="scroll-mt-14 md:scroll-mt-16 my-16 md:my-20">
      <div class="max-w-4xl mx-auto px-4 border-t pt-8 md:pt-10">
        <!-- Title -->
        <h2 class="text-brand text-xl md:text-2xl font-bold mb-8">Skills</h2>

        <div class="flex flex-col gap-10">
          <!-- Frontend (primary) -->
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-2">
              <h3 class="text-brand text-lg font-semibold">Frontend</h3>
              <span class="flex items-center gap-1 text-xs text-brand">
                <Icon name="bi:star-fill" width="12" height="12" />
                core strength
              </span>
            </div>

            <ul class="flex flex-wrap gap-2">
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                HTML
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                CSS
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                JavaScript
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                React
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Tailwind CSS
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                TypeScript
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Mobile-First Design
              </li>
            </ul>
          </div>

          <!-- Backend -->
          <div class="flex flex-col gap-3">
            <h3 class="text-muted text-lg font-semibold">Backend</h3>
            <ul class="flex flex-wrap gap-2">
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Java
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Spring Boot
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Hibernate
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                REST APIs
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                MySQL
              </li>
            </ul>
          </div>

          <!-- Other -->
          <div class="flex flex-col gap-3">
            <h3 class="text-muted text-lg font-semibold">Other</h3>
            <ul class="flex flex-wrap gap-2">
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Git
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Figma
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                UI Design
              </li>
              <li class="bg-surface-muted text-muted px-3 py-1 rounded-full">
                Collaboration
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="projects" class="scroll-mt-14 md:scroll-mt-16 my-16 md:my-20">
      <div class="max-w-4xl mx-auto px-4 border-t pt-8 md:pt-10">
        <!-- Title -->
        <h2 class="text-brand text-xl md:text-2xl font-bold mb-8">
          Projects
        </h2>
        <!-- content -->
        <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
          <!-- project cards -->
          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Portfolio Website
            </h3>
            <!-- inner content -->
            <div class="p-4 flex flex-col items-center gap-2">
              <img
                src={portfolioPreview.src}
                alt="Thumbnail of Portfolio Website"
                class="mt-4 h-48 w-full rounded mx-auto my-auto object-cover"
              />
              <p class="flex py-4">
                My personal developer website, where I show my skills, design
                thinking and projects. The website is designed fully from
                scratch in Figma, and built using Astro and Tailwind CSS.
              </p>
              <ul class="flex flex-grow flex-row flex-wrap gap-2">
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Astro
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Tailwind CSS
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  Figma
                </li>
              </ul>
              <div class="flex flex-row gap-2 py-4">
                <a
                  href="https://github.com/v-gajjar/vinay-gajjar"
                  class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand text-sm"
                  >GitHub</a
                >
              </div>
            </div>
          </div>

          <div
            class="flex flex-col items-center rounded-lg border bg-surface overflow-hidden"
          >
            <h3
              class="w-full p-2 text-center text-muted border-b font-semibold"
            >
              Minesweeper
            </h3>
            <!-- inner content -->
            <div class="p-4 flex flex-col items-center gap-2">
              <img
                src={minesweeperPreview.src}
                alt="Thumbnail of Minesweeper Game Board"
                class="mt-4 h-48 w-full rounded mx-auto my-auto object-cover"
              />
              <p class="flex py-4">
                A community-driven, open-source reimagining of the iconic
                Minesweeper game. Not another generic, copycat clone; We're
                evolving the game with modern styling and thoughtful UX.
              </p>
              <ul class="flex flex-grow flex-row flex-wrap gap-2">
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  React
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  TypeScript
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  CSS 3
                </li>
                <li
                  class="bg-surface-muted text-sm text-muted p-1 px-2 rounded-full"
                >
                  HTML 5
                </li>
              </ul>
              <div class="flex flex-row gap-2 py-4">
                <a
                  href="https://v-gajjar.github.io/Minesweeper/"
                  class="px-4 py-2 text-center w-auto rounded border border-brand text-brand text-sm"
                  >Live Demo</a
                >
                <a
                  href="https://github.com/v-gajjar/Minesweeper"
                  class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand text-sm"
                  >GitHub</a
                >
              </div>
            </div>
          </div>

          <!-- see more projects card -->
          <div
            class="flex p-6 items-center justify-center rounded-lg border bg-surface col-span-full"
          >
            <div class="flex flex-col items-center gap-4">
              <span class="text-center text-brand"
                >Want to see what else I'm building? Take a look at more
                projects on my</span
              >
              <a
                href="https://github.com/v-gajjar"
                class="px-4 py-2 text-center w-auto rounded bg-brand text-on-brand"
                >GitHub</a
              >
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- -footer -->
  <footer
    class="w-full flex flex-col items-center justify-center bg-brand text-on-brand mx-auto py-4"
  >
    <div class="flex flex-col items-center justify-center gap-2">
      <p class="text-center text-sm">© 2025 Vinay Gajjar</p>
      <ul class="flex flex-row items-center justify-center gap-4">
        <li>
          <a href="https://github.com/v-gajjar">
            <!-- GitHub icon -->
            <Icon name="bi:github" width="16" height="16" fill="currentColor" />
          </a>
        </li>

        <li>
          <a href="https://www.linkedin.com/in/vinaygajjar/">
            <!-- LinkedIn icon -->
            <Icon
              name="bi:linkedin"
              width="16"
              height="16"
              fill="currentColor"
            />
          </a>
        </li>

        <li>
          <a href="https://substack.com/@vinaygajjar?">
            <!-- Substack icon  -->
            <Icon
              name="bi:substack"
              width="16"
              height="16"
              fill="currentColor"
            />
          </a>
        </li>
      </ul>
    </div>
  </footer>

  <script>
    /*
      script to toggle expanded content in "My Story" section
    */
    const myStoryExpandedContentToggleButton = document.getElementById(
      "my-story-expanded-content-toggle-button",
    );
    const content = document.getElementById(
      "my-story-expanded-content-wrapper",
    );
    myStoryExpandedContentToggleButton.addEventListener("click", () => {
      content.classList.toggle("hidden");
      content.classList.toggle("opacity-100");
      myStoryExpandedContentToggleButton.innerText =
        myStoryExpandedContentToggleButton.innerText === "Read more"
          ? "Read less"
          : "Read more";
    });
  </script>
</Layout>
